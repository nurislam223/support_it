```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
.env
.env.local

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# Build/dist directories
build/
dist/
*.egg-info/

# OS generated files
.DS_Store
Thumbs.db

# Database files
*.db
*.sqlite
*.sqlite3

# Cache directories
.mypy_cache/
.pytest_cache/
__pycache__/
```